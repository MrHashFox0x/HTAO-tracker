# Postgres connection string. Use the POOLED / transaction-mode endpoint:
#   Supabase: Project Settings -> Database -> Connection pooling (port 6543)
#   Neon:     the "-pooler" host
#   Vercel Postgres: POSTGRES_URL
DATABASE_URL=postgres://user:password@host:6543/dbname

# Set PGSSL=disable only for a local Postgres without TLS.
# PGSSL=disable

# Pair + endpoint (defaults are correct for HTAO/USDC).
# COIN=@307
# HL_WS_URL=wss://api.hyperliquid.xyz/ws
# SNAPSHOT_EVERY_MS=60000
